{
  "name": "e-commerce",
  "private": true,
  "packageManager": "bun@1.3.14",
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/main.ts",
    "build": "prisma generate && tsc",
    "start": "bun src/main.ts",
    "vercel-build": "prisma generate && nest build",
    "db:generate": "bun --env-file=.env ./node_modules/.bin/prisma generate",
    "db:push": "bun --env-file=.env ./node_modules/.bin/prisma db push",
    "db:migrate": "bun --env-file=.env ./node_modules/.bin/prisma migrate dev",
    "db:seed": "bun --env-file=.env ./node_modules/.bin/prisma db seed"
  },
  "dependencies": {
    "@libsql/client": "^0.17.4",
    "@nest/testing": "^4.5.4",
    "@nestjs/common": "^11.1.27",
    "@nestjs/core": "^11.1.27",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mapped-types": "*",
    "@nestjs/platform-express": "^11.1.27",
    "@prisma/adapter-libsql": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@types/express": "^5.0.6",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "dotenv": "^17.4.2",
    "install": "^0.13.0",
    "nestjs-pino": "^4.6.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.5.0",
    "@nestjs/testing": "^11.1.28",
    "@prisma/compute-sdk": "latest",
    "@types/bcrypt": "^6.0.0",
    "@types/bun": "^1.3.14",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.1.1",
    "jest": "^30.4.2",
    "prisma": "^7.8.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
